<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy.MM.dd HH:mm:ss.SSS} %p [%thread] %c#%M(%L) %m%n" charset="UTF-8"/>
        </Console>
        <RollingFile name="ROLLING" fileName="logs/messageflow.log" filePattern="logs/%d{yyyy-MM}/messageflow-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{yyyy.MM.dd HH:mm:ss.SSS} %p [%thread] %c#%M(%L) %m%n" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy />
        </RollingFile>
        <RollingFile name="TRAFFIC" fileName="logs/messageflow_traffic.log" filePattern="logs/%d{yyyy-MM}/messageflow_traffic-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{yyyy.MM.dd HH:mm:ss.SSS} %m%n" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy />
            <DefaultRolloverStrategy>
                <Delete basePath="logs" maxDepth="2">
                    <IfFileName glob="*/messageflow_traffic-*.log" />
                    <IfAccumulatedFileCount exceeds="5" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Logger name="logbook.traffic" level="INFO" additivity="false">
            <AppenderRef ref="TRAFFIC"/>
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="logbook.queue.BaseConsumer" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ROLLING"/>
        </Logger>
    
        <Root level="INFO">
            <AppenderRef ref="Console" />
            <AppenderRef ref="ROLLING" />
        </Root>
    </Loggers>
</Configuration>
